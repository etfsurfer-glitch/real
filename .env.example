# Copy to .env and fill in. .env is gitignored.
# DO NOT paste the secret key in chat or commit it.

# Supabase project
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# service_role-equivalent secret key (sb_secret_...). Used ONLY by the local collector.
SUPABASE_SECRET_KEY=

# Anon/publishable key (sb_publishable_...). Used by the frontend; safe to expose.
# Kept here for convenience during local dev.
SUPABASE_ANON_KEY=

# Collector throttling
NAVER_CONCURRENCY=4
NAVER_REQUEST_DELAY_MS=250
NAVER_TIMEOUT_SEC=15
NAVER_USER_AGENT=Mozilla/5.0 (Linux; Android 13; SM-S918N) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Mobile Safari/537.36

# Local data
LOCAL_DB_PATH=./data/naverreal.sqlite
SNAPSHOT_DIR=./data/snapshots
